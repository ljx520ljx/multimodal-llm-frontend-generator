# ============================================
# 多模态 LLM 前端生成器 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ============================================
# LLM 配置 (必填)
# ============================================

# LLM 提供商: openai | anthropic | deepseek | doubao
LLM_PROVIDER=openai

# OpenAI / OpenAI 兼容 API
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o
# 可选：自定义 API 端点（如使用 OpenRouter、Azure 等）
OPENAI_BASE_URL=

# Anthropic (可选)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================
# 服务配置
# ============================================

# Go Backend
SERVER_PORT=8080
SERVER_MODE=development
ALLOWED_ORIGINS=http://localhost:3000

# Python Agent
AGENT_SERVICE_URL=http://localhost:8081
AGENT_TIMEOUT=30s

# LLM 调用超时
LLM_TIMEOUT=60s

# ============================================
# 图片处理配置
# ============================================

IMAGE_MAX_SIZE=10485760        # 单张图片最大 10MB
IMAGE_MAX_TOTAL=52428800       # 总计最大 50MB
IMAGE_QUALITY=80               # JPEG 压缩质量
IMAGE_MAX_DIMENSION=2048       # 最大边长
IMAGE_ALLOWED_TYPES=image/png,image/jpeg,image/webp

# ============================================
# 会话配置
# ============================================

SESSION_TTL=1h                 # 会话过期时间

# ============================================
# Agent 级别模型配置（可选）
# ============================================
# 如果不配置，所有 Agent 使用上面的默认模型
# 适用于统一令牌 API（如 OpenRouter）的场景

# ChatAgent 模型（对话修改，推荐 Claude 系列）
# CHAT_AGENT_MODEL=claude-sonnet-4-20250514

# Pipeline Agent 模型覆盖
# LAYOUT_AGENT_MODEL=gpt-4o           # 布局分析，需要强多模态能力
# COMPONENT_AGENT_MODEL=gpt-4o        # 组件检测，需要强多模态能力
# INTERACTION_AGENT_MODEL=claude-sonnet-4-20250514  # 交互推理
# CODEGEN_AGENT_MODEL=claude-sonnet-4-20250514      # 代码生成
# VALIDATOR_AGENT_MODEL=gpt-4o-mini   # 代码验证（轻量任务可用便宜模型）

# ============================================
# 开发配置
# ============================================

# 启用 Few-Shot 示例（提高生成质量，增加 token 消耗）
ENABLE_FEW_SHOT=false

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
