# Server Configuration
SERVER_PORT=8080
SERVER_MODE=development  # development | production

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ===================
# LLM Configuration
# ===================

# Provider Selection
# Options: openai | deepseek | doubao | gemini | anthropic
LLM_PROVIDER=openai

# Request timeout (default: 5 minutes)
LLM_TIMEOUT=300s

# -------------------
# OpenAI
# -------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o  # gpt-4o | gpt-4-turbo | gpt-3.5-turbo

# -------------------
# DeepSeek (深度求索)
# -------------------
# API: https://api.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat  # deepseek-chat | deepseek-coder

# -------------------
# Doubao (豆包 / 火山引擎)
# -------------------
# API: https://ark.cn-beijing.volces.com/api/v3
# Note: DOUBAO_MODEL must be an endpoint ID in format ep-xxx-xxx
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL=ep-your-endpoint-id

# -------------------
# Google Gemini
# -------------------
GEMINI_API_KEY=your-gemini-api-key

# -------------------
# Anthropic Claude
# -------------------
ANTHROPIC_API_KEY=your-anthropic-api-key

# ===================
# Image Processing
# ===================

# Max size per image (default: 10MB)
IMAGE_MAX_SIZE=10485760

# Max total upload size (default: 50MB)
IMAGE_MAX_TOTAL=52428800

# Compression quality 1-100 (default: 80)
IMAGE_QUALITY=80

# Max width/height in pixels (default: 2048)
IMAGE_MAX_DIMENSION=2048

# Allowed MIME types (comma-separated)
IMAGE_ALLOWED_TYPES=image/png,image/jpeg,image/webp

# ===================
# Session
# ===================

# Session expiration time (default: 30 minutes)
SESSION_TTL=30m
